{
  "manifest_version": 3,
  "name": "PopAI Notifications",
  "description": "Receive PopAI notifications in your browser",
  "version": "1.0.0",
  "key": "",
  "permissions": ["notifications", "storage"],
  "host_permissions": [
    "https://cognito-idp.us-east-2.amazonaws.com/*",
    "https://*.appsync-api.us-east-2.amazonaws.com/*",
    "https://*.googleapis.com/*",
    "https://*.firebaseio.com/*",
    "https://firebaseinstallations.googleapis.com/*",
    "https://fcmregistrations.googleapis.com/*"
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
